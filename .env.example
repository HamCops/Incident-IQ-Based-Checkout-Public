# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!
#
# This file provides a template for configuration values
# that should be stored securely in Google Apps Script
# PropertiesService or as environment variables.
#
# To set these in Google Apps Script:
# 1. Create a function in Apps Script editor
# 2. Use PropertiesService.getScriptProperties().setProperty()
# 3. Run the function once
# 4. Delete the function
# ============================================

# ============================================
# INCIDENTIQ CONFIGURATION
# ============================================

# Your IncidentIQ domain (without https://)
INCIDENTIQ_DOMAIN=yourschool.incidentiq.com

# IncidentIQ Site ID (GUID format)
# Found in: IncidentIQ Admin → Settings or JWT token claims
INCIDENTIQ_SITE_ID=00000000-0000-0000-0000-000000000000

# IncidentIQ Asset View ID (GUID format)
# Create a view in IncidentIQ with devices available for checkout
# Found in: IncidentIQ → Assets → Views → [Your View] → URL
INCIDENTIQ_ASSET_VIEW_ID=00000000-0000-0000-0000-000000000000

# IncidentIQ API Token (JWT format - long string)
# Generate in: IncidentIQ → Administration → Developer Tools
# CRITICAL: Never commit this to version control!
INCIDENTIQ_API_TOKEN=your_jwt_token_here

# IncidentIQ Status GUIDs
# Found in: IncidentIQ → Settings → Asset Statuses
INCIDENTIQ_MISSING_STATUS_GUID=00000000-0000-0000-0000-000000000000
INCIDENTIQ_IN_SERVICE_STATUS_GUID=00000000-0000-0000-0000-000000000000

# ============================================
# GOOGLE WORKSPACE CONFIGURATION
# ============================================

# Google Spreadsheet ID (found in spreadsheet URL)
# https://docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Docs Template ID (for charge sheets)
# Create a charge sheet template and get ID from URL
# https://docs.google.com/document/d/[THIS_IS_THE_ID]/edit
GOOGLE_DOC_TEMPLATE_ID=your_template_id_here

# ============================================
# NOTIFICATION EMAIL ADDRESSES
# ============================================

# IT Staff Email Addresses (comma-separated)
# These receive daily alerts and error notifications
IT_STAFF_EMAIL_1=admin@example.com
IT_STAFF_EMAIL_2=tech@example.com

# Charge Sheet Recipients (comma-separated)
# These receive charge sheet notifications
CHARGE_SHEET_EMAIL_1=admin@example.com
CHARGE_SHEET_EMAIL_2=billing@example.com

# ============================================
# SCHOOL INFORMATION
# ============================================

# School Name (displayed in emails and forms)
SCHOOL_NAME=Your School Name

# School Email Domain (for email validation)
# Used in Validators.gs - update @yourschool.org
SCHOOL_EMAIL_DOMAIN=yourschool.org

# General School Contact Email
SCHOOL_CONTACT_EMAIL=info@yourschool.org

# School Phone Number
SCHOOL_PHONE=555-123-4567

# School Physical Address
SCHOOL_ADDRESS=123 Main Street, City, ST 12345

# School Timezone (for notifications)
# Examples: America/New_York, America/Chicago, America/Los_Angeles
SCHOOL_TIMEZONE=America/New_York

# ============================================
# DEVICE REPLACEMENT COSTS
# ============================================

# Update these with your school's actual device costs
COST_CHROMEBOOK=217.00
COST_CHARGER=140.00
COST_LAPTOP=400.00
COST_TABLET=300.00

# ============================================
# OPERATIONAL SETTINGS
# ============================================

# Cutoff time for same-day returns (24-hour format)
CUTOFF_TIME=14:20

# Daily notification schedule
MORNING_UPDATE_TIME=07:00
AFTERNOON_UPDATE_TIME=14:30
CHARGE_SHEET_TIME=15:15

# Charge sheet threshold (days overdue)
CHARGE_SHEET_THRESHOLD_DAYS=3

# Return deadline after charge sheet (business days)
RETURN_DEADLINE_DAYS=2

# ============================================
# SECURITY SETTINGS
# ============================================

# Maximum active checkouts per student
MAX_ACTIVE_CHECKOUTS=1

# Rate limiting (requests per minute per user)
MAX_REQUESTS_PER_MINUTE=10

# Rate limit lockout duration (minutes)
LOCKOUT_DURATION_MINUTES=15

# API timeout (milliseconds)
API_TIMEOUT_MS=30000

# ============================================
# HIGH SCHOOL FILTERING (Optional)
# ============================================

# Enable high school filtering for faster user search
# Set to true if your email format includes graduation year prefixes
ENABLE_HS_FILTERING=true

# Current high school graduation years (comma-separated)
# Update annually - e.g., "25,26,27,28"
HS_GRAD_YEARS=26,27,28,29

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Enable debug logging (set to false in production)
DEBUG_MODE=false

# Test user email (for development only)
TEST_USER_EMAIL=test.user@yourschool.org

# Test asset tag (for development only)
TEST_ASSET_TAG=123456

# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. Copy this file to .env (not tracked by git)
# 2. Fill in all values above
# 3. In Google Apps Script, create this function:
#
#    function setupConfiguration() {
#      const properties = PropertiesService.getScriptProperties();
#      properties.setProperty('INCIDENTIQ_API_TOKEN', 'your_token_here');
#      Logger.log('Configuration saved securely');
#    }
#
# 4. Run setupConfiguration() once
# 5. Delete the function or remove the token from code
# 6. Update Config.gs with non-sensitive values
# 7. Update Validators.gs with your email domain
#
# ============================================
